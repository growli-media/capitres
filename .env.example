# ---------------------------------------------------------------
# Wayl payment gateway — https://wayl.io  (API: api.thewayl.com)
# ---------------------------------------------------------------
# Merchant token from dashboard.wayl.io. LEAVE UNSET to run the
# storefront in mock-payment mode (local simulated gateway).
WAYL_API_TOKEN=

# "test" or "live" — sent as `env` when creating payment links.
WAYL_ENV=test

# Secret you generate yourself; Wayl signs webhook bodies with it
# (HMAC-SHA256, header `x-wayl-signature-256`).
WAYL_WEBHOOK_SECRET=

# Override only for Wayl sandbox/staging environments.
# WAYL_BASE_URL=https://api.thewayl.com

# ---------------------------------------------------------------
# Database — Postgres (Vercel Postgres / Neon / any standard host)
# ---------------------------------------------------------------
# Powers the catalog, orders and the /admin dashboard. LEAVE UNSET to
# run the storefront off the hardcoded demo catalog with no admin panel
# (useful for quick local UI work). Local dev: run `npm run db:dev` in
# one terminal (starts an embedded Postgres on port 55432), then use
# the URL below. Production: Vercel Postgres/Neon fill this in
# automatically when you attach the integration in the dashboard.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:55432/postgres

# ---------------------------------------------------------------
# Image uploads — Vercel Blob
# ---------------------------------------------------------------
# Powers photo uploads in /admin/products. LEAVE UNSET locally — new
# product photos are simply rejected with a clear error until this is
# set. Get the token from Vercel dashboard → Storage → Blob → Connect.
BLOB_READ_WRITE_TOKEN=

# ---------------------------------------------------------------
# Admin dashboard — /admin
# ---------------------------------------------------------------
# The one login the client uses to manage products, discounts, stock
# and see KPIs/abandoned carts. Set a real password before deploying —
# the login page refuses to work with this placeholder.
ADMIN_PASSWORD=change-me
# Random string used to sign the admin session cookie. Generate one
# with: openssl rand -hex 32
ADMIN_SESSION_SECRET=change-me-too

# ---------------------------------------------------------------
# Analytics & ad tracking — all LEAVE UNSET to run with none of this
# wired up (nothing breaks; the scripts simply don't load). Set the
# ones the client actually has accounts for.
# ---------------------------------------------------------------
# GA4 — Google Analytics 4 "Measurement ID", starts with G-
NEXT_PUBLIC_GA4_ID=

# Google Ads conversion tracking ID, starts with AW- (Google Ads →
# Tools → Conversions → your conversion action → "Google tag").
NEXT_PUBLIC_GOOGLE_ADS_ID=
# The specific label from that same conversion action, the part after
# the "/" in the tag Google gives you (e.g. AW-123456789/AbC-D_efGhIjK).
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=

# Meta (Facebook/Instagram) Pixel ID — Events Manager → your pixel →
# Settings. Also used for the server-side Conversions API below.
NEXT_PUBLIC_META_PIXEL_ID=
# Conversions API access token — Events Manager → your pixel →
# Settings → Conversions API → Generate access token. Sends a
# server-side copy of each Purchase event, which meaningfully improves
# ad match quality (browser-only Pixel tracking loses events to ad
# blockers and iOS). LEAVE UNSET to skip server-side sending — the
# browser Pixel above still works fine on its own.
META_CAPI_ACCESS_TOKEN=

# Microsoft Clarity project ID — clarity.microsoft.com → your project →
# Settings → Setup. Free session recordings + heatmaps — this is what
# actually answers "who stayed how long on which page."
NEXT_PUBLIC_CLARITY_ID=

# Full site URL (no trailing slash) — improves Meta Conversions API
# event quality and is used as the default Open Graph base.
NEXT_PUBLIC_SITE_URL=https://capitres.com
